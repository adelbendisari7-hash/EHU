# ── Base de données PostgreSQL (Neon.tech recommandé — gratuit) ──────────────
# Obtenir sur : https://neon.tech → Create project → Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Authentification NextAuth.js ──────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="votre-secret-aleatoire-32-caracteres"

# URL de l'application déployée (mettre l'URL Vercel après premier déploiement)
NEXTAUTH_URL="https://votre-app.vercel.app"

# ── Email (optionnel — récupération de mot de passe) ─────────────────────────
# Obtenir sur : https://resend.com (gratuit 3000 emails/mois)
RESEND_API_KEY=""
FROM_EMAIL="no-reply@votre-domaine.dz"
